# Supabase
SUPABASE_PROJECT_ID="tu-project-id"
SUPABASE_PUBLISHABLE_KEY="tu-publishable-key"
SUPABASE_URL="https://tu-proyecto.supabase.co"
SUPABASE_SERVICE_ROLE_KEY="tu-service-role-key"

# Resend (para emails de confirmación)
RESEND_API_KEY="re_..."

# Google Calendar OAuth
GOOGLE_CLIENT_ID="tu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="tu-client-secret"

# URL base de la app (sin barra al final). Usado para redirect URI de Google Calendar
# En local: http://localhost:8080
# En producción: https://tudominio.com
APP_URL="http://localhost:8080"
